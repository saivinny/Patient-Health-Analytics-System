insights <- data.frame(
Insight = c(
"Age is the strongest predictor",
"Hypertension raises stroke risk",
"Heart disease increases stroke risk",
"Smoking is associated with stroke",
"Sedentary lifestyle is risky",
"High glucose links to high risk",
"Gender differences exist",
"Data quality is good"
),
Finding = c(
"Older patients consistently have higher stroke risk scores",
"Patients with hypertension have more strokes than those without",
"Both male and female patients with heart disease have more strokes",
"Smokers and former smokers have higher stroke counts in both genders",
"Sedentary patients have the highest stroke counts in the dataset",
"Higher glucose levels are positively correlated with stroke risk score",
"Patterns of heart disease and smoking risk appear in both male and female groups",
"No missing values and no duplicates — the dataset is clean and complete"
),
stringsAsFactors = FALSE
)
kable(insights,
caption   = "Summary of key trends and insights from the EDA",
col.names = c("Insight", "Finding"),
row.names = FALSE)
